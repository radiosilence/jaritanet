#!/usr/bin/env bash
# Populate the SINGBOX_* GitHub Actions secrets that feed the ansible singbox
# role, sourced from an existing hosted profile JSON. Values are piped straight
# to `gh` — never printed. Telegram bot creds are prompted (chat id is
# auto-detected from the bot's recent messages); skip them with
# SINGBOX_SKIP_NOTIFY=1.
#
#   ./scripts/set-singbox-secrets https://files.radiosilence.dev/.sfm/<slug>.json
set -euo pipefail

REPO="${SINGBOX_REPO:-radiosilence/jaritanet}"
URL="${1:-${SINGBOX_SOURCE_URL:-}}"

if [[ -z "$URL" ]]; then
  echo "usage: $0 <existing-profile-url>" >&2
  exit 1
fi

echo "Fetching $URL ..." >&2
json="$(curl -fsSL "$URL")"

set_secret() { # name value
  [[ -n "$2" ]] || { echo "  !! empty value for $1, skipping" >&2; return; }
  printf '%s' "$2" | gh secret set "$1" --repo "$REPO"
  echo "  set $1" >&2
}
jq_get() { jq -er "$1" <<<"$json"; }

# Slug + hostname derive from the URL itself
set_secret SINGBOX_SLUG "$(basename "$URL" .json)"
set_secret FILES_HOSTNAME "$(sed -E 's#^https?://([^/]+)/.*#\1#' <<<"$URL")"

set_secret SINGBOX_VPS_IP                  "$(jq_get '.outbounds[]|select(.tag=="hy2").server')"
set_secret SINGBOX_HYSTERIA_AUTH_PASSWORD  "$(jq_get '.outbounds[]|select(.tag=="hy2").password')"
set_secret SINGBOX_HYSTERIA_OBFS_PASSWORD  "$(jq_get '.outbounds[]|select(.tag=="hy2").obfs.password')"
set_secret SINGBOX_XRAY_UUID               "$(jq_get '.outbounds[]|select(.tag=="reality").uuid')"
set_secret SINGBOX_XRAY_SERVER_NAME        "$(jq_get '.outbounds[]|select(.tag=="reality").tls.server_name')"
set_secret SINGBOX_XRAY_PUBLIC_KEY         "$(jq_get '.outbounds[]|select(.tag=="reality").tls.reality.public_key')"
set_secret SINGBOX_XRAY_SHORT_ID           "$(jq_get '.outbounds[]|select(.tag=="reality").tls.reality.short_id')"
set_secret SINGBOX_TAILNET_MAGICDNS_SUFFIX "$(jq_get '.dns.rules[0].domain_suffix[0]')"

if [[ -n "${SINGBOX_SKIP_NOTIFY:-}" ]]; then
  echo "Skipped Telegram creds (SINGBOX_SKIP_NOTIFY set)." >&2
  exit 0
fi

echo >&2
echo "Telegram bot (for pushing the profile — leave blank to skip):" >&2
echo "  Create a bot with @BotFather, then send it any message first." >&2
read -rsp "  Bot token: " tg_token; echo >&2

tg_chat=""
if [[ -n "$tg_token" ]]; then
  # Auto-detect chat id from the most recent message sent to the bot
  tg_chat="$(curl -fsSL "https://api.telegram.org/bot${tg_token}/getUpdates" \
    | jq -r '[.result[].message.chat.id] | last // empty')"
  if [[ -n "$tg_chat" ]]; then
    echo "  Detected chat id: $tg_chat" >&2
  else
    echo "  Could not auto-detect (send your bot a message first)." >&2
    read -rp "  Chat id: " tg_chat
  fi
fi

set_secret TELEGRAM_BOT_TOKEN "$tg_token"
set_secret TELEGRAM_CHAT_ID   "$tg_chat"

echo "Done." >&2
