{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "id": "https://raw.githubusercontent.com/radiosilence/jaritanet/main/schemas/routes.json",
  "title": "Routes Configuration Schema",
  "description": "Schema for routes configuration",
  "type": "object",
  "properties": {
    "config": {
      "type": "object",
      "properties": {
        "jaritanet-routes:cloudflare": {
          "type": "object",
          "properties": {
            "accountId": {
              "description": "Cloudflare account ID.",
              "type": "string"
            }
          },
          "required": ["accountId"],
          "additionalProperties": false
        },
        "jaritanet-routes:zones": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "zoneId": {
                "description": "The Cloudflare ID of the zone.",
                "type": "string"
              },
              "name": {
                "description": "The name of the zone.",
                "type": "string"
              },
              "modules": {
                "description": "DNS modules to apply.",
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["bluesky", "fastmail"]
                }
              }
            },
            "required": ["zoneId", "name", "modules"],
            "additionalProperties": false
          }
        },
        "jaritanet-routes:serviceStacks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string"
              },
              "stack": {
                "type": "string"
              }
            },
            "required": ["path"],
            "additionalProperties": false
          }
        },
        "jaritanet-routes:bluesky": {
          "type": "object",
          "properties": {
            "did": {
              "description": "Bluesky requires a DID to be set in the DNS records for authentication.",
              "type": "string"
            }
          },
          "required": ["did"],
          "additionalProperties": false
        },
        "jaritanet-routes:fastmail": {
          "type": "object",
          "properties": {
            "mxDomain": {
              "type": "string"
            },
            "dkimDomain": {
              "type": "string"
            },
            "dkimSubdomain": {
              "type": "string"
            },
            "dmarcSubdomain": {
              "type": "string"
            },
            "dmarcAggEmail": {
              "type": "string"
            },
            "dmarcPolicy": {
              "type": "string"
            },
            "spfDomain": {
              "type": "string"
            }
          },
          "required": [
            "mxDomain",
            "dkimDomain",
            "dkimSubdomain",
            "dmarcSubdomain",
            "dmarcAggEmail",
            "dmarcPolicy",
            "spfDomain"
          ],
          "additionalProperties": false
        },
        "cloudflare:apiToken": {
          "type": "object",
          "properties": {
            "apiToken": {
              "type": "string"
            }
          },
          "required": ["apiToken"],
          "additionalProperties": false
        }
      },
      "required": [
        "jaritanet-routes:cloudflare",
        "jaritanet-routes:zones",
        "jaritanet-routes:serviceStacks",
        "jaritanet-routes:bluesky",
        "jaritanet-routes:fastmail",
        "cloudflare:apiToken"
      ],
      "additionalProperties": false
    }
  },
  "required": ["config"],
  "additionalProperties": false
}
