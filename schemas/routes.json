{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Schema for routes configuration",
  "id": "https://raw.githubusercontent.com/radiosilence/jaritanet/main/schemas/routes.json",
  "properties": {
    "config": {
      "properties": {
        "cloudflare:apiToken": {
          "properties": {
            "secure": {
              "type": "string"
            }
          },
          "required": ["secure"],
          "type": "object"
        },
        "jaritanet-routes:bluesky": {
          "properties": {
            "did": {
              "description": "Bluesky requires a DID to be set in the DNS records for authentication.",
              "type": "string"
            }
          },
          "required": ["did"],
          "type": "object"
        },
        "jaritanet-routes:cloudflare": {
          "properties": {
            "accountId": {
              "description": "Cloudflare account ID.",
              "type": "string"
            }
          },
          "required": ["accountId"],
          "type": "object"
        },
        "jaritanet-routes:fastmail": {
          "properties": {
            "dkimDomain": {
              "type": "string"
            },
            "dkimSubdomain": {
              "type": "string"
            },
            "dmarcAggEmail": {
              "type": "string"
            },
            "dmarcPolicy": {
              "type": "string"
            },
            "dmarcSubdomain": {
              "type": "string"
            },
            "mxDomain": {
              "type": "string"
            },
            "spfDomain": {
              "type": "string"
            }
          },
          "required": [
            "mxDomain",
            "dkimDomain",
            "dkimSubdomain",
            "dmarcSubdomain",
            "dmarcAggEmail",
            "dmarcPolicy",
            "spfDomain"
          ],
          "type": "object"
        },
        "jaritanet-routes:serviceStacks": {
          "items": {
            "properties": {
              "path": {
                "type": "string"
              },
              "stack": {
                "type": "string"
              }
            },
            "required": ["path"],
            "type": "object"
          },
          "type": "array"
        },
        "jaritanet-routes:zones": {
          "items": {
            "properties": {
              "modules": {
                "description": "DNS modules to apply.",
                "items": {
                  "enum": ["bluesky", "fastmail"],
                  "type": "string"
                },
                "type": "array"
              },
              "name": {
                "description": "The name of the zone.",
                "type": "string"
              },
              "zoneId": {
                "description": "The Cloudflare ID of the zone.",
                "type": "string"
              }
            },
            "required": ["zoneId", "name", "modules"],
            "type": "object"
          },
          "type": "array"
        }
      },
      "required": [
        "jaritanet-routes:cloudflare",
        "jaritanet-routes:zones",
        "jaritanet-routes:serviceStacks",
        "jaritanet-routes:bluesky",
        "jaritanet-routes:fastmail",
        "cloudflare:apiToken"
      ],
      "type": "object"
    }
  },
  "required": ["config"],
  "title": "Routes Configuration Schema",
  "type": "object"
}
